# Keep the build context small and free of host cruft / secrets.
.git
.github
logs/
*.egg-info/
ANIME_RECOMMENDER.egg-info/
# rebuilt inside the image; never ship the host copy. NOTE: docker only treats a
# line as a comment when '#' is the FIRST character -- a trailing comment here would
# become part of the pattern and silently match nothing.
chroma_db/
.env
.env.*
.claude
# google-github-actions/auth writes gha-creds-<random>.json into GITHUB_WORKSPACE
# BEFORE the build step, so `COPY . .` bakes it into the image. It is a Workload
# Identity external-account config (not a private key), but it must never ship.
gha-creds-*.json
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
# docs / planning — not needed in the image
*.md

# infra / manifests / IaC — not part of the app image
k8s/
k8s-local/
terraform/

# security scanning configs + outputs — never shipped in the app image
# (the app's API lives in app/api.py, which IS included; the scanners are not)
security/
promptfoo/
redteam-cyberseceval/
reports/
llmsec/

# local virtualenvs + tool caches (host-only; the image builds its own /opt/venv)
venv/
.appvenv/
.secops*/
node_modules/
